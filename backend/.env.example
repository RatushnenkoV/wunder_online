# Скопируй в .env и заполни значения
# cp .env.example .env

# -------------------------------------------------------
# Обязательные
# -------------------------------------------------------

# Сгенерируй: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# True только для разработки
DEBUG=False

# Домены через запятую (без пробелов)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# -------------------------------------------------------
# База данных (PostgreSQL для продакшена)
# -------------------------------------------------------

DB_ENGINE=django.db.backends.postgresql
DB_NAME=wunder_db
DB_USER=wunder_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# -------------------------------------------------------
# CORS — разрешённые источники (фронтенд)
# -------------------------------------------------------

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -------------------------------------------------------
# Redis (для WebSocket / Django Channels)
# -------------------------------------------------------

REDIS_URL=redis://127.0.0.1:6379
